---
import BlogLayout from '../layouts/BlogLayout.astro';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Konte Solutions",
  "description": "Agencia de software a medida para PYMES. Especialistas en Google Sheets, AppScript, dashboards en tiempo real y formularios de alta conversión.",
  "url": "https://konte.es/servicios",
  "serviceType": [
    "Automatización Google Sheets",
    "Desarrollo AppScript",
    "Dashboards Looker Studio",
    "Formularios Lead Magnet",
    "Software a Medida"
  ],
  "areaServed": {
    "@type": "Country",
    "name": "España"
  },
  "priceRange": "Consultar presupuesto"
});

const services = [
  {
    id: "mejora-hojas-calculo",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3z"/><path d="M3 9h18"/><path d="M9 3v18"/><path d="M13 13l2 2 4-4"/></svg>`,
    title: "Optimización Pro de Google Sheets",
    subtitle: "De hojas lentas a sistemas de alto rendimiento",
    description: "Auditamos y reconstruimos tus hojas de cálculo. Eliminamos el lag, corregimos fórmulas complejas y creamos una arquitectura de datos escalable que no se rompe.",
    whenToUse: "¿Tu archivo tarda segundos en calcular? ¿Varios usuarios rompen las fórmulas sin querer? Necesitas una base técnica sólida.",
    benefits: [
      "Auditoría técnica de rendimiento y errores",
      "Arquitectura de datos relacional (Base de Datos)",
      "Protección de celdas y validación avanzada",
      "Sistemas de búsqueda y filtrado ultra-rápidos",
      "Limpieza de duplicados y normalización"
    ],
    accent: "blue",
    image: "/img/servicios/sheets.png"
  },
  {
    id: "automatizacion-appscript",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: "Automatización con Motores AppScript",
    subtitle: "Tu empresa trabajando mientras tú descansas",
    description: "Programamos 'robots' internos que ejecutan tareas por ti: facturación automática, avisos por email, sincronización con CRMs y reportes nocturnos.",
    whenToUse: "Si hay tareas que se repiten 'cada lunes', 'cada vez que entra un pedido' o 'al final del día', la automatización es obligatoria.",
    benefits: [
      "Triggers automáticos por tiempo o evento",
      "Integración total con Gmail, Drive y Calendar",
      "Envío masivo y personalizado de documentos",
      "Conexión con APIs externas (Stripe, WhatsApp...)",
      "Registro de errores y logs de ejecución"
    ],
    accent: "blue",
    image: "/img/servicios/automation.png"
  },
  {
    id: "software-customizado",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>`,
    title: "Web-Apps a Medida (Ecosistema Google)",
    subtitle: "Software potente, interfaz profesional, coste cero de servidor",
    description: "Creamos aplicaciones web privadas para tu equipo. Con menús, formularios dinámicos y paneles de gestión, pero usando Google Sheets como base de datos.",
    whenToUse: "Cuando necesitas que tu equipo use una herramienta 'que parezca una App' y no una simple hoja de cálculo con pestañas interminables.",
    benefits: [
      "Interfaz de usuario (UI) moderna y limpia",
      "Control de accesos y roles (Admin/User)",
      "Gestión de flujos de trabajo (Estados/Aprobaciones)",
      "Adaptado a móviles y tablets (Responsive)",
      "Sin cuotas mensuales de alojamiento (0€/mes)"
    ],
    accent: "blue",
    image: "/img/servicios/webapp.png"
  },
  {
    id: "creacion-formularios",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M9 2h6"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>`,
    title: "Sistemas de Captura de Datos",
    subtitle: "Orden absoluto desde el primer clic",
    description: "Formularios inteligentes que validan la información antes de guardarla. Olvídate de datos mal escritos, campos vacíos o formatos incorrectos.",
    whenToUse: "Si la información que te llega de clientes o empleados es un caos y pierdes tiempo corrigiéndola antes de trabajar.",
    benefits: [
      "Lógica condicional (preguntas dinámicas)",
      "Carga de archivos y fotos integrada",
      "Firmas digitales en el propio formulario",
      "Validación de NIF/CIF, emails y teléfonos",
      "Notificaciones push automáticas al recibir datos"
    ],
    accent: "blue",
    image: "/img/servicios/forms.png"
  },
  {
    id: "formularios-leads-magnet",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/><circle cx="12" cy="12" r="9"/></svg>`,
    title: "Sistemas Lead Magnet & Captación",
    subtitle: "Tu web vendiendo por ti 24/7",
    description: "Diseñamos el embudo técnico para tus campañas. Formularios que no solo captan, sino que segmentan y califican al cliente automáticamente en tu CRM.",
    whenToUse: "Si haces Ads o tienes tráfico en la web pero no conviertes, o si los leads se quedan 'en el limbo' sin seguimiento inmediato.",
    benefits: [
      "Landing pages de alta conversión incluidas",
      "Auto-respuestas personalizadas al instante",
      "Asignación inteligente de leads al equipo",
      "Trackeo de procedencia (Google/Facebook/RRSS)",
      "Cálculo de ROI por lead integrado"
    ],
    accent: "blue",
    image: "/img/servicios/leads.png"
  },
  {
    id: "dashboards-tiempo-real",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>`,
    title: "Dashboards y BI en Tiempo Real",
    subtitle: "Visibilidad total para decisiones inteligentes",
    description: "Convertimos tus datos en paneles visuales impactantes. Controla tus ventas, stock o márgenes con un solo vistazo desde tu móvil.",
    whenToUse: "Cuando sientes que no tienes el control de los números o dependes de que alguien te envíe un Excel a final de mes para saber qué pasa.",
    benefits: [
      "Visualización en Looker Studio o Custom Dashboard",
      "Filtros avanzados por fecha, comercial o producto",
      "Predicción de tendencias basada en histórico",
      "Acceso compartido y seguro para socios",
      "Alertas automáticas de KPIs críticos"
    ],
    accent: "blue",
    image: "/img/servicios/dashboards.png"
  }
];
---

<BlogLayout
  title="Servicios de Automatización Google Sheets y AppScript | Konte"
  description="Mejora tus hojas de cálculo, automatiza con AppScript, crea dashboards en tiempo real y formularios lead magnet. Software a medida para PYMES sin costes de mantenimiento."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative py-20 md:py-28 bg-white dark:bg-black border-b border-gray-100 dark:border-gray-900 overflow-hidden text-center">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-lightAccent rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="inline-block px-4 py-2 bg-gray-900 text-white font-bold text-xs uppercase tracking-widest mb-6">Nuestros Servicios</div>
      <h1 class="font-display text-5xl md:text-7xl font-black uppercase tracking-tight mb-6 leading-[0.9] text-gray-900 dark:text-white">
        Digitaliza tu operativa.<br/>
        <span class="text-lightAccent">Sin límites.</span>
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed font-medium">
        Transformamos procesos manuales en sistemas de alta ingeniería sobre Google Workspace. Sin servidores, sin mantenimiento, propiedad 100% tuya.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 bg-white dark:bg-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12">
        {services.map((service, i) => (
          <article id={service.id} class="flex flex-col md:flex-row border-2 border-gray-100 dark:border-gray-800 rounded-3xl overflow-hidden hover:border-lightAccent transition-all duration-500 hover:shadow-2xl group/card">
            <!-- Left: Info -->
            <div class="flex-1 p-8 md:p-14 bg-gray-900 relative">
              <div class="relative z-10">
                <div class="flex items-start justify-between mb-8">
                  <div class="w-20 h-20 text-lightAccent bg-lightAccent/10 p-4 rounded-2xl border border-lightAccent/20 group-hover/card:scale-110 transition-transform duration-500" set:html={service.icon} />
                  <span class="text-5xl font-black text-white tracking-tighter opacity-10">0{i + 1}</span>
                </div>
                
                <h2 class="font-display text-3xl md:text-5xl font-black uppercase tracking-tight mb-4 text-white leading-tight">
                  {service.title}
                </h2>
                <p class="text-lightAccent font-black text-sm uppercase tracking-widest mb-6">{service.subtitle}</p>
                <p class="text-xl text-gray-300 leading-relaxed mb-10 font-medium">{service.description}</p>
                
                <div class="p-8 bg-white/5 border-l-8 border-lightAccent rounded-r-2xl shadow-sm">
                  <p class="text-[10px] font-black uppercase tracking-[0.2em] text-lightAccent mb-3">¿Cuándo necesito este servicio?</p>
                  <p class="text-white font-bold text-lg md:text-xl leading-relaxed">"{service.whenToUse}"</p>
                </div>
              </div>
            </div>

            <!-- Right: Details -->
            <div class="w-full md:w-[450px] p-8 md:p-14 bg-gray-50 dark:bg-black/40 border-l border-gray-100 dark:border-gray-800 flex flex-col justify-between">
              <div>
                <h3 class="text-xs font-black uppercase tracking-widest text-gray-400 mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">¿Qué incluye?</h3>
                <ul class="space-y-6">
                  {service.benefits.map(b => (
                    <li class="flex items-start gap-4">
                      <div class="w-6 h-6 bg-lightAccent/10 text-lightAccent rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </div>
                      <span class="text-base font-bold text-gray-700 dark:text-gray-300 leading-tight">{b}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="mt-12">
                <a href="/#calendly" class="group flex items-center justify-between w-full p-6 bg-gray-900 dark:bg-white text-white dark:text-black font-black text-sm uppercase tracking-widest transition-all hover:bg-lightAccent dark:hover:bg-lightAccent hover:text-white shadow-[8px_8px_0_0_rgba(0,0,0,1)] dark:shadow-[8px_8px_0_0_rgba(255,255,255,0.1)] hover:shadow-none hover:translate-x-1 hover:translate-y-1">
                  Evaluar Viabilidad
                  <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing Philosophy -->
  <section class="py-24 bg-gray-950 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
        <div class="absolute -bottom-24 -right-24 w-[500px] h-[500px] bg-lightAccent rounded-full blur-[120px]"></div>
    </div>
    <div class="max-w-5xl mx-auto px-4 relative z-10">
      <h2 class="font-display text-5xl md:text-7xl font-black uppercase mb-8 text-white leading-[0.85] tracking-tighter">
        Inversión única.<br/><span class="text-lightAccent">Cero costes fijos.</span>
      </h2>
      <p class="text-xl text-gray-400 mb-16 max-w-3xl mx-auto leading-relaxed">
        Eliminamos la tiranía del SaaS mensual. Construimos tu propia tecnología para que seas dueño total de tu operativa y tus datos.
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
          <div class="p-10 bg-white/5 backdrop-blur-md border border-white/10 rounded-[32px] text-left hover:border-lightAccent transition-colors">
              <div class="text-5xl font-black text-lightAccent mb-4">0€</div>
              <div class="text-xs font-black uppercase tracking-widest text-white mb-3">Mantenimiento</div>
              <p class="text-sm text-gray-500 leading-relaxed">Sin servidores, sin licencias, sin sorpresas a final de mes.</p>
          </div>
          <div class="p-10 bg-white/5 backdrop-blur-md border border-white/10 rounded-[32px] text-left hover:border-lightAccent transition-colors">
              <div class="text-5xl font-black text-lightAccent mb-4">100%</div>
              <div class="text-xs font-black uppercase tracking-widest text-white mb-3">Propiedad</div>
              <p class="text-sm text-gray-500 leading-relaxed">El código es tuyo. Si mañana quieres cambiar algo, puedes.</p>
          </div>
          <div class="p-10 bg-white/5 backdrop-blur-md border border-white/10 rounded-[32px] text-left hover:border-lightAccent transition-colors">
              <div class="text-5xl font-black text-lightAccent mb-4">24/7</div>
              <div class="text-xs font-black uppercase tracking-widest text-white mb-3">Disponibilidad</div>
              <p class="text-sm text-gray-500 leading-relaxed">Infraestructura Google con 99.9% de tiempo de actividad.</p>
          </div>
      </div>

      <a href="/#calendly" class="inline-flex items-center gap-4 px-12 py-7 bg-lightAccent text-white font-black text-xl uppercase tracking-widest hover:scale-105 transition-all shadow-[20px_20px_60px_-15px_rgba(0,85,255,0.3)]">
        Hablar con un consultor
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>
  </section>
</BlogLayout>
