---
import Layout from '../layouts/Layout.astro';
import BeforeAfterSlider from '../components/BeforeAfterSlider.jsx';
import LeadDiagnosisForm from '../components/LeadDiagnosisForm.jsx';
import CircularText from '../components/reactbits/CircularText';
import BlurText from '../components/reactbits/BlurText';
import DecryptedText from '../components/reactbits/DecryptedText';
import LeadMagnetForm from '../components/LeadMagnetForm.jsx';
import ProjectGallery from '../components/ProjectGallery.jsx';

const projects = [
  {
    tags: ['Gastronomía', 'Control de Inventario', 'App Integral'],
    title: 'Inventario Multi-Sede: FlagShip',
    desc: 'Una <strong>app de inventario</strong> diseñada para gestionar los utensilios y equipamiento en cientos de cafeterías por todo Estados Unidos. Escalabilidad total y sincronización en tiempo real.',
    folder: 'FlagShip',
    logo: 'logo.png',
    mainImg: '1.png',
    thumbs: ['Captura de pantalla 2026-04-01 124439.png', 'Captura de pantalla 2026-04-01 124448.png']
  },
  {
    tags: ['Manufactura', 'Gestión de Lotes'],
    title: 'Aplicación Integral de Producción: Montelimar',
    desc: 'Un sistema integral para la <strong>gestión de procesos</strong> y <strong>control de temperatura</strong>. Permite a los operarios saber qué fabricar, controlar las variables de la <strong>cámara de curado</strong> y lotes, mientras los jefes visualizan dashboards de rendimiento en tiempo real sin perder datos en papel.',
    folder: 'Montelimar',
    logo: 'logo.png',
    mainImg: '1.png',
    thumbs: ['image copy.png', 'image copy 2.png']
  },
  {
    tags: ['Logística Autopartes', 'Control de Stock Automotriz'],
    title: 'Software de Inventario Dinámico: Recomotor',
    desc: 'Una plataforma para la <strong>trazabilidad de recambios</strong> e inventariado de cada vehículo mediante escáner. Cualquier empleado puede registrar trazabilidad actualizando el flujo de entrada y salida, asegurando una gestión total del <strong>stock de talleres</strong>.',
    folder: 'Recomotor',
    logo: 'logo.png',
    mainImg: '1.png',
    thumbs: ['Untitled design (2).png', 'Untitled design (3).png']
  },
  {
    tags: ['Salud & Fitness', 'Planificador de Rutinas'],
    title: 'App Integral para Entrenadores',
    desc: 'Un <strong>dashboard de seguimiento de clientes</strong> para entrenadores deportivos. Control absoluto y <strong>gestión de pagos recurrentes</strong>, asignación de rutinas personalizadas, centralizando historiales y ahorrando un 80% del tiempo organizativo manual.',
    folder: 'Gestion Gym -Entrenador personal',
    logo: 'logo.png',
    mainImg: '1.png',
    thumbs: ['Captura de pantalla 2026-03-31 181347.png', 'Captura de pantalla 2026-03-31 181353.png', 'Captura de pantalla 2026-03-31 181404.png']
  },
  {
    tags: ['Agroindustria', 'Gestión de Materia Prima'],
    title: 'Hefe: ERP de Automatización Agrícola',
    desc: 'De caos logístico a control maestro. Los operarios visualizan en piso la <strong>escalabilidad de recetas industriales</strong>, el sistema computa el alta de las <strong>órdenes de producción y stock</strong> automáticamente, actuando como un <strong>ERP a medida</strong> 100% digitalizado.',
    folder: 'Hefe - Planta fertilizantes',
    logo: 'logo.png',
    mainImg: '1.png',
    thumbs: ['Captura de pantalla 2026-03-31 175019.png', 'Captura de pantalla 2026-03-31 175208.png', 'Captura de pantalla 2026-03-31 175213.png']
  },
  {
    tags: ['Construcción', 'Flujo de Caja'],
    title: 'Gestor Financiero Constructoras',
    desc: 'Sistema de alta capacidad para la auditoría y el <strong>control de presupuestos de obra</strong>. Un robusto <strong>dashboard financiero</strong> donde se supervisan gastos de proveedores, flujos de pagos y el índice de <strong>rentabilidad por proyecto</strong>.',
    folder: 'Gestor Financiero Constructoras',
    logo: 'logo.png',
    mainImg: '1.png',
    thumbs: ['Captura de pantalla 2026-03-31 190931.png', 'Captura de pantalla 2026-03-31 190950.png']
  }
];

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfessionalService",
      "name": "Konte Solutions",
      "url": "https://konte.es",
      "description": "Agencia de software a medida para PYMES. Especialistas en Google Sheets, AppScript, automatización y dashboards en tiempo real sin costes de mantenimiento mensual.",
      "areaServed": "España",
      "serviceType": ["Automatización Google Sheets", "Desarrollo AppScript", "Dashboards Looker Studio", "Software a Medida PYME"]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "¿Por qué no pago mantenimiento mensual?", "acceptedAnswer": { "@type": "Answer", "text": "Porque nuestro software corre directamente sobre la infraestructura de Google Workspace. No hay servidores propios que mantener. El sistema vive en tu cuenta de Google y tú eres el propietario total del código y los datos." } },
        { "@type": "Question", "name": "¿Es seguro usar Google Sheets como base de datos para mi empresa?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Google Workspace cumple con ISO 27001, SOC 2 y SOC 3, con cifrado en tránsito y en reposo. Para la mayoría de PYMES es más seguro que un servidor propio." } },
        { "@type": "Question", "name": "¿Cuánto cuesta un proyecto de software a medida con Konte?", "acceptedAnswer": { "@type": "Answer", "text": "Cada proyecto se presupuesta individualmente: desde mejoras de hojas de cálculo (300-500€) hasta aplicaciones web completas (2.500-8.000€). El pago es único y no hay cuotas mensuales." } },
        { "@type": "Question", "name": "¿Puedo automatizar procesos en Google Sheets sin saber programar?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Nosotros nos encargamos de toda la programación en Google Apps Script. Tú describes el proceso y nosotros lo implementamos con formación incluida." } },
        { "@type": "Question", "name": "¿En cuánto tiempo estará listo mi proyecto?", "acceptedAnswer": { "@type": "Answer", "text": "Las automatizaciones simples pueden estar listas en 1-2 semanas. Las aplicaciones web completas se entregan en 4-8 semanas según la complejidad." } },
        { "@type": "Question", "name": "¿Funciona si ya tenemos muchos datos en Excel?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Google Sheets importa archivos .xlsx de forma nativa conservando fórmulas y datos. Realizamos la migración como parte del proyecto." } }
      ]
    }
  ]
});
---

<Layout
  title="Konte | Software a Medida para PYMES con Google Sheets y AppScript"
  description="Digitaliza tu PYME con software a medida sin costes de mantenimiento. Especialistas en Google Workspace, AppScript y Looker Studio. ¡Agenda tu diagnóstico gratuito!"
  jsonLd={jsonLd}
>
  <!-- Navbar -->
  <nav class="fixed w-full top-0 z-50 bg-lightBg/80 dark:bg-black/80 backdrop-blur-md border-b border-gray-200 dark:border-gray-900 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-lightAccent dark:bg-darkAccent text-white dark:text-black flex items-center justify-center font-display font-black text-2xl rotate-3 hover:rotate-0 transition-transform">K</div>
          <span class="font-display font-bold text-2xl tracking-tight uppercase">Konte</span>
        </div>
        
        <div class="flex items-center gap-6">
          <a href="#soluciones" class="hidden md:block text-sm font-bold hover:text-lightAccent dark:hover:text-darkAccent transition-colors">Soluciones</a>
          <a href="#proyectos" class="hidden md:block text-sm font-bold hover:text-lightAccent dark:hover:text-darkAccent transition-colors">Proyectos</a>
          <a href="/servicios" class="hidden md:block text-sm font-bold hover:text-lightAccent dark:hover:text-darkAccent transition-colors">Servicios</a>
          <a href="/blog" class="hidden md:block text-sm font-bold hover:text-lightAccent dark:hover:text-darkAccent transition-colors">Blog</a>
          
          <button id="theme-toggle" class="hidden p-2 rounded-lg bg-gray-200 dark:bg-darkSurface hover:bg-gray-300 dark:hover:bg-gray-800 transition-colors" aria-label="Toggle Theme">
            <svg id="theme-toggle-light-icon" class="hidden w-5 h-5 text-darkAccent" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path>
            </svg>
            <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5 text-lightAccent" fill="currentColor" viewBox="0 0 20 20">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
            </svg>
          </button>
          
          <button id="nav-calendly-btn" class="px-6 py-2.5 bg-lightAccent dark:bg-darkAccent text-white dark:text-black font-bold text-sm tracking-wide rounded-sm hover:-translate-y-1 transition-transform shadow-[4px_4px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_4px_0_0_rgba(255,255,255,0.2)]">Evaluar Proyecto</button>
        </div>
      </div>
    </div>
  </nav>

  <main class="pt-32 pb-16 bg-white dark:bg-black">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 mb-8 text-center">
      <div class="max-w-5xl mx-auto">
        <h1 class="font-display text-5xl md:text-6xl font-black mb-8 text-gray-900 dark:text-white uppercase leading-[0.9] tracking-tighter">
          Software A Medida.<br />
          <span class="text-lightAccent dark:text-darkAccent">Cero Mantenimiento Mensual.</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-10 max-w-2xl mx-auto font-medium leading-relaxed">
          Diseñamos, desarrollamos e implementamos sistemas operativos internos para PYMES. Sin costes mensuales absurdos, construido sobre tu infraestructura de Google.
        </p>

        <!-- Premium Value Blocks Repeated from Services -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16 max-w-5xl mx-auto px-4">
            <div class="p-8 bg-gray-50 dark:bg-white/5 backdrop-blur-md border border-gray-200 dark:border-white/10 rounded-[32px] text-center hover:border-lightAccent transition-all group">
                <div class="text-5xl font-black text-lightAccent mb-4 group-hover:scale-110 transition-transform">0€</div>
                <div class="text-xs font-black uppercase tracking-widest text-gray-900 dark:text-white mb-3">Mantenimiento</div>
                <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed font-medium">Sin servidores, sin licencias, sin sorpresas a final de mes.</p>
            </div>
            <div class="p-8 bg-gray-50 dark:bg-white/5 backdrop-blur-md border border-gray-200 dark:border-white/10 rounded-[32px] text-center hover:border-lightAccent transition-all group">
                <div class="text-5xl font-black text-lightAccent mb-4 group-hover:scale-110 transition-transform">100%</div>
                <div class="text-xs font-black uppercase tracking-widest text-gray-900 dark:text-white mb-3">Propiedad</div>
                <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed font-medium">El código es tuyo. Si mañana quieres cambiar algo, puedes.</p>
            </div>
            <div class="p-8 bg-gray-50 dark:bg-white/5 backdrop-blur-md border border-gray-200 dark:border-white/10 rounded-[32px] text-center hover:border-lightAccent transition-all group">
                <div class="text-5xl font-black text-lightAccent mb-4 group-hover:scale-110 transition-transform">24/7</div>
                <div class="text-xs font-black uppercase tracking-widest text-gray-900 dark:text-white mb-3">Disponibilidad</div>
                <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed font-medium">Infraestructura Google con 99.9% de tiempo de actividad.</p>
            </div>
        </div>
      </div>

      <!-- Componente Dinámico: Formulario Inline -->
      <LeadDiagnosisForm client:load />

    </section>

    <!-- Componente Interactivo: Before vs After -->
    <section id="comparativa" class="w-full py-8 md:py-12 mb-0 dark:bg-black transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <BeforeAfterSlider client:load />
      </div>
    </section>

    <!-- Interactive Demo Section -->
    <section id="demo" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-24 mb-16 dark:bg-black transition-colors relative overflow-hidden">
      <div class="bg-gray-50 dark:bg-gray-900 border-4 border-black shadow-[16px_16px_0_0_rgba(0,0,0,1)] p-8 pt-16 md:p-16 md:pt-20 text-center relative z-10">
        <!-- Floating Badge -->
        <div class="absolute -top-4 md:-top-6 left-1/2 -translate-x-1/2 bg-lightAccent text-white font-black px-4 md:px-6 py-2 text-[10px] md:text-base uppercase tracking-widest border-4 border-black rotate-1 shadow-[4px_4px_0_0_rgba(0,0,0,1)] z-20 whitespace-nowrap">
            Acceso Instantáneo Hoy
        </div>
        
        <h2 class="font-display text-4xl md:text-6xl font-black uppercase mb-6 leading-tight text-gray-900 dark:text-white">
          Prueba el Futuro de<br/>tu Gestión <span class="text-lightAccent">Hoy</span>
        </h2>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-10 max-w-2xl mx-auto font-medium">
            No imagines cómo sería tu sistema a medida. <strong>Úsalo ahora mismo</strong>. Hemos preparado una demo interactiva completa para que navegues por el dashboard, clientes y ventas.
        </p>

        <form id="demo-form" action="https://formspree.io/f/myklqoqp" method="POST" class="max-w-2xl mx-auto flex flex-col md:flex-row gap-4 bg-white dark:bg-gray-800 p-2 border-4 border-black shadow-[8px_8px_0_0_rgba(0,0,0,1)]">
          <input 
            type="email" 
            name="email" 
            required 
            placeholder="Introduce tu email profesional" 
            class="flex-1 p-4 bg-transparent font-bold focus:outline-none text-gray-900 dark:text-white"
          />
          <button 
            type="submit" 
            class="bg-lightAccent text-white font-black uppercase px-10 py-4 border-4 border-black shadow-[4px_4px_0_0_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all flex items-center justify-center gap-2 group"
          >
            <span>PROBAR DEMO</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </button>
        </form>
        
        <div class="mt-8 flex flex-wrap justify-center gap-6">
            <span class="text-xs font-black text-gray-400 uppercase tracking-widest flex items-center gap-2">
                <i class="fa fa-check text-lightAccent"></i> Navegación Real
            </span>
            <span class="text-xs font-black text-gray-400 uppercase tracking-widest flex items-center gap-2">
                <i class="fa fa-check text-lightAccent"></i> KPIs en Tiempo Real
            </span>
            <span class="text-xs font-black text-gray-400 uppercase tracking-widest flex items-center gap-2">
                <i class="fa fa-check text-lightAccent"></i> Sin Instalaciones
            </span>
        </div>
      </div>
    </section>

    <!-- The Zero Maintenance Model (Cero Costes Ocultos) -->
    <section id="soluciones" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 mb-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block px-4 py-2 bg-lightText dark:bg-darkText text-lightSurface dark:text-darkSurface font-bold text-sm uppercase tracking-widest mb-6">Nuestra Ventaja Injusta</div>
          <h2 class="font-display text-4xl md:text-6xl font-black uppercase mb-8 leading-tight">Por qué nuestro software cuesta 0€/mes en servidores.</h2>
          <p class="text-lg text-lightTextSec dark:text-darkTextSec mb-6 leading-relaxed">
            Las agencias tradicionales te venden un SaaS y te cobran cientos de euros al mes solo por mantenerlo vivo en AWS o Azure. Nosotros somos diferentes.
          </p>
          <p class="text-lg text-lightTextSec dark:text-darkTextSec mb-8 leading-relaxed">
            Utilizamos <strong>Tecnología "Serverless"</strong> conectada directamente a tu Google Workspace (Google Sheets, Looker Studio, Apps Script). Tú eres dueño del código, dueño de los datos, y <strong class="text-lightAccent dark:text-darkAccent">no pagas mantenimiento</strong>.
          </p>
          <button id="hero-calendly-btn" class="inline-flex items-center gap-2 font-bold text-lightAccent dark:text-darkAccent hover:opacity-80 text-xl border-b-2 border-transparent hover:border-current transition-all pb-1">
            Descubrir si es viable para mi empresa &rarr;
          </button>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <!-- Web Apps Box -->
          <div class="p-6 md:p-8 min-h-[280px] bg-gray-100 dark:bg-darkSurface border-2 border-gray-200 dark:border-gray-800 flex flex-col justify-between group overflow-hidden relative cursor-pointer feature-card transition-all duration-300">
            <div class="w-16 h-16 relative">
               <svg class="absolute inset-0 w-full h-full text-lightTextSec dark:text-darkTextSec group-hover:text-lightAccent dark:group-hover:text-darkAccent transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="4" width="20" height="14" rx="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M8 21h8" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 18v3" stroke-linecap="round" stroke-linejoin="round"/>
                  <line x1="6" y1="9" x2="18" y2="9" stroke-linecap="round" stroke-dasharray="12" class="animate-[pulse_1.5s_infinite]"/>
                  <line x1="6" y1="13" x2="12" y2="13" stroke-linecap="round" stroke-dasharray="6" class="animate-[pulse_2s_infinite]"/>
               </svg>
            </div>
            <div>
               <span class="font-display font-bold text-lg md:text-xl uppercase relative z-10 transition-colors">Web Apps Nativas</span>
               <p class="card-text hidden mt-3 text-xs md:text-sm text-gray-500 font-medium">Despliegue de interfaces ultrarrápidas y a medida sin los costes prohibitivos de servidores de backend tradicionales.</p>
            </div>
          </div>

          <!-- Looker Studio Box -->
          <div class="p-6 md:p-8 min-h-[280px] bg-gray-100 dark:bg-darkSurface border-2 border-gray-200 dark:border-gray-800 flex flex-col justify-between group overflow-hidden relative cursor-pointer feature-card transition-all duration-300">
            <div class="w-16 h-16 flex items-end gap-1.5 pb-2">
              <div class="w-3 bg-lightTextSec dark:bg-darkTextSec group-hover:bg-lightAccent dark:group-hover:bg-darkAccent transition-colors anim-graph-1"></div>
              <div class="w-3 bg-lightTextSec dark:bg-darkTextSec group-hover:bg-lightAccent dark:group-hover:bg-darkAccent transition-colors anim-graph-2"></div>
              <div class="w-3 bg-lightTextSec dark:bg-darkTextSec group-hover:bg-lightAccent dark:group-hover:bg-darkAccent transition-colors anim-graph-3"></div>
              <div class="w-3 bg-lightTextSec dark:bg-darkTextSec group-hover:bg-lightAccent dark:group-hover:bg-darkAccent transition-colors anim-graph-4"></div>
            </div>
            <div>
               <span class="font-display font-bold text-lg md:text-xl uppercase relative z-10 transition-colors">Looker Studio</span>
               <p class="card-text hidden mt-3 text-xs md:text-sm text-gray-500 font-medium">Dashboards en vivo que conectan directamente con tus operaciones diarias. Visualiza y decide en base a datos reales.</p>
            </div>
          </div>

          <!-- Automations Box -->
          <div class="p-6 md:p-8 min-h-[280px] bg-gray-100 dark:bg-darkSurface border-2 border-gray-200 dark:border-gray-800 flex flex-col justify-between group overflow-hidden relative cursor-pointer feature-card transition-all duration-300">
            <div class="w-16 h-16 flex items-center justify-center">
              <svg class="w-full h-full text-lightTextSec dark:bg-darkTextSec group-hover:text-lightAccent dark:group-hover:text-darkAccent transition-colors duration-300 animate-[spin_8s_linear_infinite]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
              </svg>
            </div>
            <div>
               <span class="font-display font-bold text-lg md:text-xl uppercase relative z-10 transition-colors">Automatización</span>
               <p class="card-text hidden mt-3 text-xs md:text-sm text-gray-500 font-medium">Scripts de Google (AppScript) programados a medida que corren por detrás de escena y generan alertas sin cobrarte ejecución.</p>
            </div>
          </div>

          <!-- DB Box -->
          <div class="p-6 md:p-8 min-h-[280px] bg-lightAccent dark:bg-darkAccent text-white dark:text-black flex flex-col justify-between shadow-[8px_8px_0_0_rgba(0,0,0,1)] dark:shadow-[8px_8px_0_0_rgba(255,255,255,0.1)] group relative overflow-hidden cursor-pointer feature-card transition-all duration-300">
            <div class="w-16 h-16 flex flex-col gap-2 justify-center">
              <div class="w-full h-4 border-2 border-current rounded-sm relative overflow-hidden bg-black/10 dark:bg-white/10">
                 <div class="absolute inset-y-0 left-0 bg-current anim-db-1"></div>
              </div>
              <div class="w-full h-4 border-2 border-current rounded-sm relative overflow-hidden bg-black/10 dark:bg-white/10">
